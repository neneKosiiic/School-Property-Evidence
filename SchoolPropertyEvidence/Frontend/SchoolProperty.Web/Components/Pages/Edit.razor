@page "/edit"
@inject NavigationManager Nav

<PageTitle>Edit Record</PageTitle>

<h1>Edit Record</h1>
<p>Choose a mock item and update its details.</p>

<div class="mb-3">
    <label class="form-label">Select item</label>
    <select class="form-select" @bind="SelectedItemId">
        <option value="1">1 - Laptop</option>
        <option value="2">2 - Projector</option>
        <option value="3">3 - Desk</option>
        <option value="4">4 - Whiteboard</option>
    </select>
</div>
<div class="mb-3">
    <label class="form-label">Name</label>
    <input class="form-control" @bind="Name" />
</div>
<div class="mb-3">
    <label class="form-label">Category</label>
    <input class="form-control" @bind="Category" />
</div>
<div class="mb-3">
    <label class="form-label">Room</label>
    <input class="form-control" @bind="Room" />
</div>
<div class="mb-3">
    <label class="form-label">Owner</label>
    <input class="form-control" @bind="Owner" />
</div>

<button class="btn btn-primary me-2" @onclick="Save">Save Changes</button>
<button class="btn btn-secondary" @onclick="Cancel">Cancel</button>

@if (!string.IsNullOrEmpty(Message))
{
    <div class="alert alert-success mt-3">@Message</div>
}

@code {
    private int SelectedItemId = 1;
    private string Name = "Laptop";
    private string Category = "Electronics";
    private string Room = "Room A";
    private string Owner = "John Doe";
    private string Message;

    private void Save()
    {
        Message = $"Mock item {SelectedItemId} updated successfully. (No backend yet.)";
    }

    private void Cancel()
    {
        Nav.NavigateTo("/home");
    }
}