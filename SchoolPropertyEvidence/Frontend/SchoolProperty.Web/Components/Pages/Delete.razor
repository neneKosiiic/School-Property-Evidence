@page "/delete"
@inject NavigationManager Nav

<PageTitle>Delete Record</PageTitle>

<h1>Delete Record</h1>
<p>Select a mock item and delete it from the list.</p>

<div class="mb-3">
    <label class="form-label">Select item</label>
    <select class="form-select" @bind="SelectedItemId">
        <option value="1">1 - Laptop</option>
        <option value="2">2 - Projector</option>
        <option value="3">3 - Desk</option>
        <option value="4">4 - Whiteboard</option>
    </select>
</div>

<button class="btn btn-danger me-2" @onclick="DeleteItem">Delete</button>
<button class="btn btn-secondary" @onclick="Cancel">Cancel</button>

@if (!string.IsNullOrEmpty(Message))
{
    <div class="alert alert-warning mt-3">@Message</div>
}

@code {
    private int SelectedItemId = 1;
    private string Message;

    private void DeleteItem()
    {
        Message = $"Mock item {SelectedItemId} deleted successfully. (No backend yet.)";
    }

    private void Cancel()
    {
        Nav.NavigateTo("/home");
    }
}